{
  "hash": {
    "supported_algorithms": ["md5", "sha1", "sha256"],
    "default_algorithm": "sha256"
  },
  "resource": {
    "max_usage_ratio": 0.7
  },
  "file_processing": {
    "small_file_threshold": 10485760,
    "buffer_size": 262144
  },
  "common_excludes": [
    ".idea",
    ".git",
    ".svn",
    "__pycache__",
    ".env",
    ".vscode"
  ]
}